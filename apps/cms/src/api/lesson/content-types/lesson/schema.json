{
  "kind": "collectionType",
  "collectionName": "lessons",
  "info": {
    "singularName": "lesson",
    "pluralName": "lessons",
    "displayName": "Lesson"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text"
    },
    "preview": {
      "type": "media",
      "multiple": false,
      "allowedTypes": [
        "images"
      ]
    },
    "position": {
      "type": "integer",
      "required": false,
      "unique": false,
      "min": 0
    },
    "content": {
      "type": "blocks",
      "private": true
    },
    "heroSrcType": {
      "type": "enumeration",
      "private": true,
      "required": true,
      "default": "none",
      "enum": [
        "none",
        "url",
        "embed"
      ]
    },
    "heroUrl": {
      "type": "string",
      "private": true,
      "conditions": {
        "visible": {
          "==": [
            {
              "var": "heroSrcType"
            },
            "url"
          ]
        }
      },
      "regex": "^https:\\/\\/rutube\\.ru\\/video\\/private\\/[a-f0-9]{32}\\/?(?:\\?p=[A-Za-z0-9_-]+)?$"
    },
    "course": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::course.course",
      "inversedBy": "lessons"
    }
  }
}
